    {
      "parameters": {
        "jsCode": "const invoiceData = $('Get Invoice').first().json;\nconst billableRate = invoiceData['Billable Rate'] ? invoiceData['Billable Rate'][0] : 0;\nconst invoiceDate = invoiceData['Date'] || new Date().toISOString().split('T')[0];\nconst invoiceNumber = invoiceData['Invoice #'];\nconst zohoCustomerID = invoiceData['Zoho Customer ID'] ? invoiceData['Zoho Customer ID'][0] : null;\n\nconst lineItems = [];\n\nfunction resolveField(field, fallback = '') {\n  if (field === null || field === undefined) return fallback;\n  if (Array.isArray(field)) return field[0] ?? fallback;\n  if (typeof field === 'object') return field.value ?? fallback;\n  return field;\n}\n\nconst allItems = $input.all();\n\nallItems.forEach(item => {\n  const data = item.json;\n\n  if (data['_empty']) return;\n\n  if (data['Week']) {\n    // Time entry\n    const title = resolveField(data['Title'], 'Time Entry');\n    const description = resolveField(data['Description'], title);\n    const hours = Math.round((data['Total Hours'] || 0) * 100) / 100;\n    const date = resolveField(data['Date']);\n    const projectName = resolveField(data['Project Name'], 'Consulting Services');\n\n    lineItems.push({\n      name: `${date}: ${projectName}`,\n      description: description,\n      rate: billableRate,\n      quantity: hours\n    });\n\n  } else if (data['Amount']) {\n    // Expense\n    const expenseName = resolveField(data['Expense Name'], 'Expense');\n    const amount = resolveField(data['Amount'], 0);\n    const date = resolveField(data['Date']);\n    const notes = resolveField(data['Notes']);\n    const category = resolveField(data['Category']);\n\n    lineItems.push({\n      name: 'Expense',\n      description: `${date}: ${expenseName}${category ? ' (' + category + ')' : ''}${notes ? ' - ' + notes : ''}`,\n      rate: amount,\n      quantity: 1\n    });\n\n  } else if (data['Miles']) {\n    // Mileage\n    const miles = resolveField(data['Miles'], 0);\n    const date = resolveField(data['Date']);\n    const notes = resolveField(data['Notes']);\n    const rate = resolveField(data['Rate'], 0);\n\n    lineItems.push({\n      name: 'Mileage',\n      description: `${date}: ${notes || 'Mileage'}`,\n      rate: rate,\n      quantity: miles\n    });\n  }\n});\n\nreturn [{\n  json: {\n    customer_id: zohoCustomerID,\n    invoice_number: invoiceNumber,\n    date: invoiceDate,\n    line_items: lineItems,\n    notes: `Thank You!`\n  }\n}];"
      },
